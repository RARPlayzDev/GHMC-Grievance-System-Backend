{
  "name": "ghmc-grievance-mvp",
  "version": "1.0.0",
  "private": true,
  "description": "GHMC Grievance Management Platform — MVP Monorepo",
  "scripts": {
    "dev": "cd services/api && npm run dev",
    "build": "cd services/api && npm run build",
