# ═══════════════════════════════════════════════════════
# GHMC Grievance Platform — Environment Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════

# === Environment ===
NODE_ENV=development                     # development | staging | production
GHMC_CURRENT_PHASE=3                     # 1-5, controls feature availability
DEMO_MODE=true                           # Enables [DEMO MODE] indicators
PORT=3000

# === Database (Supabase — free tier) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# === AI Services (Groq — free tier) ===
GROQ_API_KEY=gsk_your_api_key_here
GROQ_MODEL_TEXT=llama3-8b-8192
GROQ_MODEL_VISION=llama-3.2-90b-vision-preview
GROQ_MODEL_WHISPER=whisper-large-v3
GROQ_RATE_LIMIT_DAILY=14400
GROQ_RATE_LIMIT_MINUTE=10

# === Redis (Upstash — free tier) ===
UPSTASH_REDIS_URL=https://your-endpoint.upstash.io
UPSTASH_REDIS_TOKEN=your_token_here

# === Storage ===
STORAGE_PROVIDER=supabase                # supabase | s3
SUPABASE_STORAGE_BUCKET=complaint-photos

# === Security ===
JWT_SECRET=your-supabase-jwt-secret
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176

# === External Integrations (Deferred — leave empty for DEMO MODE) ===
SMS_PROVIDER=none                        # none | bsnl
WHATSAPP_PROVIDER=none                   # none | bsnl
BSNL_SMS_API_KEY=
BSNL_WHATSAPP_API_KEY=
IMD_API_KEY=                             # Empty = use seeded monsoon calendar
HMDA_API_KEY=                            # Empty = return empty permit list

# === Monitoring ===
BETTERSTACK_API_KEY=
LOG_LEVEL=info                           # debug | info | warn | error

# === Feature Flags ===
ENABLE_AI_CATEGORIZATION=true
ENABLE_PHOTO_DIFF=false                  # Enable in Phase 3+
ENABLE_FRAUD_SCORING=false               # Enable in Phase 3+
ENABLE_SURGE_FORECAST=false              # Enable in Phase 2+
